# ==============================================================
# TEMPLATE: PRODUCTION
# Copy nội dung này vào .env khi build trỏ về production
# Điền URL thật vào sau khi có domain
# ==============================================================
VITE_API_USER_SERVICE=https://
VITE_API_BLOG_SERVICE=https://
VITE_API_FILE_SERVICE=https://

# Vite proxy — chỉ dùng khi npm run dev trỏ về prod server
VITE_BACKEND_HOST=
VITE_BACKEND_USER_PORT=
VITE_BACKEND_BLOG_PORT=
VITE_BACKEND_FILE_PORT=

# Ví dụ — single-server (Nginx):
# VITE_API_USER_SERVICE=https://yourdomain.com/api
# VITE_API_BLOG_SERVICE=https://yourdomain.com/api
# VITE_API_FILE_SERVICE=https://yourdomain.com/api

# Ví dụ — multi-server (mỗi service 1 subdomain):
# VITE_API_USER_SERVICE=https://user-api.yourdomain.com/api
# VITE_API_BLOG_SERVICE=https://blog-api.yourdomain.com/api
# VITE_API_FILE_SERVICE=https://file-api.yourdomain.com/api

VITE_APP_TITLE=Blog Management System
VITE_ENV=production
