# ==============================================================
# TEMPLATE: DEV SERVER
# Copy nội dung này vào .env khi build trỏ về dev server
# Điền URL thật vào sau khi có server
# ==============================================================
VITE_API_USER_SERVICE=http://
VITE_API_BLOG_SERVICE=http://
VITE_API_FILE_SERVICE=http://

# Vite proxy — chỉ dùng khi npm run dev trỏ về dev server
VITE_BACKEND_HOST=
VITE_BACKEND_USER_PORT=
VITE_BACKEND_BLOG_PORT=
VITE_BACKEND_FILE_PORT=

# Ví dụ — single-server (Nginx):
# VITE_API_USER_SERVICE=http://dev.yourdomain.com/api
# VITE_API_BLOG_SERVICE=http://dev.yourdomain.com/api
# VITE_API_FILE_SERVICE=http://dev.yourdomain.com/api

# Ví dụ — multi-server (mỗi service 1 port):
# VITE_API_USER_SERVICE=http://dev.yourdomain.com:9001/api
# VITE_API_BLOG_SERVICE=http://dev.yourdomain.com:8083/api
# VITE_API_FILE_SERVICE=http://dev.yourdomain.com:8085/api

VITE_APP_TITLE=Blog Management System - Development
VITE_ENV=development
