# ==============================================================
# LOCAL DEV — Vite proxy forward /api/* đến backend
# Đổi port tùy backend đang chạy ở đâu:
#   Docker:  user=9001, blog=8083, file=8085
#   Local (mvn spring-boot:run): user=8081, blog=8082, file=8083
# ==============================================================
VITE_API_USER_SERVICE=/api
VITE_API_BLOG_SERVICE=/api
VITE_API_FILE_SERVICE=/api

# Vite proxy — host và ports của backend
# Backend Docker:  host=localhost, user=9001, blog=8083, file=8085
# Backend local (mvn spring-boot:run): host=localhost, user=8081, blog=8082, file=8083
VITE_BACKEND_HOST=localhost
VITE_BACKEND_USER_PORT=8081
VITE_BACKEND_BLOG_PORT=8082
VITE_BACKEND_FILE_PORT=8083

VITE_APP_TITLE=Blog Management System
VITE_ENV=local
